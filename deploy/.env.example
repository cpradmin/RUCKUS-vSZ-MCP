# Ruckus vSZ MCP Server - Environment Configuration
# Copy this file to .env and fill in your credentials
#
# Configuration is defined in config.yaml. This file only contains:
# - Controller credentials (referenced by username_env/password_env in config.yaml)
# - API key for security (referenced by api_key_env in config.yaml)
# - Optional IP whitelist

# =============================================================================
# CONTROLLER CREDENTIALS
# =============================================================================
# These are referenced by username_env/password_env in config.yaml
# Each controller in config.yaml specifies which env vars to use

# Controller 1 (Production)
VSZ_PROD_USERNAME=admin
VSZ_PROD_PASSWORD=your_secure_password

# Controller 2 (DR/Lab) - add as needed
# VSZ_DR_USERNAME=admin
# VSZ_DR_PASSWORD=dr_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Bearer token for API authentication (REQUIRED for production)
# Generate with: openssl rand -hex 32
VSZ_API_KEY=your-generated-api-key-from-openssl-rand-hex-32

# IP whitelisting (comma-separated CIDRs, optional)
# VSZ_ALLOWED_IPS=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,127.0.0.1/32

# =============================================================================
# SERVER SETTINGS
# =============================================================================
LOG_LEVEL=INFO
