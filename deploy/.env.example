# Ruckus vSZ MCP Server - Environment Configuration
# Copy this file to .env and fill in your credentials

# Ruckus vSZ Configuration (REQUIRED)
RUCKUS_VSZ_URL=https://your-vsz-controller.example.com:8443
RUCKUS_VSZ_USERNAME=admin
RUCKUS_VSZ_PASSWORD=your_secure_password

# Optional Settings
RUCKUS_VSZ_VERIFY_SSL=true
RUCKUS_VSZ_TIMEOUT=30
RUCKUS_VSZ_API_VERSION=v11_0

# Server Settings
LOG_LEVEL=INFO
