# Git attributes for RUCKUS vSZ MCP

# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf

# Configuration files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Exclude from exports
.gitattributes export-ignore
.gitignore export-ignore
